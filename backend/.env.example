# Porta do servidor
PORT=4000

# Conexão com MongoDB (substitua pela sua string de conexão)
MONGO_URI=mongodb://localhost:27017/ava2

# Chave JWT para assinatura de tokens (mude para algo forte)
JWT_SECRET=troca_ate_32_chars

# Chave para OpenWeatherMap (cadastre em https://openweathermap.org/)
OPENWEATHER_API_KEY=
